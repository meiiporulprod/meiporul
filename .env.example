# ── Crawler + Pipeline (root .env) ──────────────────────────────────────────

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Reddit — uses public JSON API, no credentials needed

# Twitter/X monitoring — requires one spare Twitter account in the pool
# twscrape uses guest tokens via this account; never use your main account
# TWSCRAPE_USERNAME=your_twitter_username
# TWSCRAPE_PASSWORD=your_twitter_password
# TWSCRAPE_EMAIL=email@example.com
# TWSCRAPE_EMAIL_PASSWORD=email_password   # only if different from Twitter password

# Instagram monitoring — optional auth (improves rate limits)
# INSTAGRAM_USERNAME=your_instagram_username
# INSTAGRAM_PASSWORD=your_instagram_password

# AI backend: false = Ollama (local), true = Claude API
USE_CLAUDE=false
AI_MODEL=gemma3

# Required only when USE_CLAUDE=true
# ANTHROPIC_API_KEY=sk-ant-...


# ── Frontend (frontend/.env.local) ───────────────────────────────────────────
# Copy these two into frontend/.env.local (never put service role key here)

# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
